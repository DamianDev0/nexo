                "method": "DELETE",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/pipelines/{{pipeline_id}}",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "pipelines", "{{pipeline_id}}"]
                },
                "description": "**Requires ADMIN.**\n\nReturns 400 if the pipeline is the default or if it is the only pipeline. Returns 204 on success."
              }
            },
            {
              "name": "Replace pipeline stages",
              "request": {
                "method": "PATCH",
