                },
                "description": "**Requires VIEWER. Cached 5 min.**\n\nReturns all pipelines with their stages ordered by position."
              }
            },
            {
              "name": "Get pipeline",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/pipelines/{{pipeline_id}}",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "pipelines", "{{pipeline_id}}"]
                },
                "description": "**Requires VIEWER. Cached 5 min.**"
              }
            },
            {
              "name": "Create pipeline",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }
                ],
                "url": {
                  "raw": "{{NEXOURL}}/settings/pipelines",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "pipelines"]
                },
                "body": {
                  "mode": "raw",
                  "options": { "raw": { "language": "json" } },
                  "raw": "{\n  \"name\": \"Sales Pipeline\",\n  \"isDefault\": true,\n  \"stages\": [\n    { \"name\": \"Prospecting\",   \"color\": \"#6B7280\", \"probability\": 10,  \"position\": 0 },\n    { \"name\": \"Qualification\", \"color\": \"#3B82F6\", \"probability\": 25,  \"position\": 1 },\n    { \"name\": \"Proposal\",      \"color\": \"#8B5CF6\", \"probability\": 50,  \"position\": 2 },\n    { \"name\": \"Negotiation\",   \"color\": \"#F59E0B\", \"probability\": 75,  \"position\": 3 },\n    { \"name\": \"Closed Won\",    \"color\": \"#22C55E\", \"probability\": 100, \"position\": 4 },\n    { \"name\": \"Closed Lost\",   \"color\": \"#EF4444\", \"probability\": 0,   \"position\": 5 }\n  ]\n}"
                },
                "description": "**Requires ADMIN.**\n\nIf `isDefault: true`, the current default pipeline is unset automatically. At least one stage is required."
              }
            },
            {
              "name": "Update pipeline",
