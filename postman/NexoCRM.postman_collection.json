        {
          "name": "Navigation",
          "item": [
            {
              "name": "Get sidebar config",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/navigation",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "navigation"]
                },
                "description": "**Requires VIEWER.**\n\nReturns the ordered list of sidebar modules with enabled/disabled state."
              }
            },
            {
              "name": "Update sidebar config",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }
                ],
                "url": {
                  "raw": "{{NEXOURL}}/settings/navigation",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "navigation"]
                },
                "body": {
                  "mode": "raw",
                  "options": { "raw": { "language": "json" } },
                  "raw": "{\n  \"modules\": [\n    { \"key\": \"dashboard\",  \"label\": \"Dashboard\",     \"icon\": \"home\",        \"enabled\": true,  \"order\": 1, \"customIconUrl\": null, \"required\": true  },\n    { \"key\": \"contacts\",   \"label\": \"Clientes\",      \"icon\": \"users\",       \"enabled\": true,  \"order\": 2, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"companies\",  \"label\": \"Empresas\",      \"icon\": \"building\",    \"enabled\": true,  \"order\": 3, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"deals\",      \"label\": \"Negocios\",      \"icon\": \"trending-up\", \"enabled\": true,  \"order\": 4, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"activities\", \"label\": \"Actividades\",   \"icon\": \"calendar\",    \"enabled\": true,  \"order\": 5, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"invoices\",   \"label\": \"Facturas\",      \"icon\": \"file-text\",   \"enabled\": true,  \"order\": 6, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"products\",   \"label\": \"Productos\",     \"icon\": \"package\",     \"enabled\": false, \"order\": 7, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"reports\",    \"label\": \"Reportes\",      \"icon\": \"bar-chart\",   \"enabled\": true,  \"order\": 8, \"customIconUrl\": null, \"required\": false },\n    { \"key\": \"settings\",   \"label\": \"Configuración\", \"icon\": \"settings\",    \"enabled\": true,  \"order\": 9, \"customIconUrl\": null, \"required\": true  }\n  ]\n}"
                },
                "description": "**Requires ADMIN.**\n\nFull replacement — send the complete ordered list. Modules with `required: true` (`dashboard`, `settings`) cannot be disabled — the server rejects with 400."
              }
            }
          ]
        },

        {
          "name": "Custom Fields",
          "item": [
            {
              "name": "Get all custom fields",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/custom-fields",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "custom-fields"]
                },
                "description": "**Requires ADMIN.**\n\nReturns custom field definitions for all entities: `{ contacts: [], companies: [], deals: [] }`"
              }
            },
            {
              "name": "Get custom fields for entity",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/custom-fields/{{entity}}",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "custom-fields", "{{entity}}"]
                },
                "description": "**Requires ADMIN.**\n\nEntity: `contacts` | `companies` | `deals`"
              }
            },
            {
              "name": "Replace custom fields for entity",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }
                ],
                "url": {
                  "raw": "{{NEXOURL}}/settings/custom-fields/{{entity}}",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "custom-fields", "{{entity}}"]
                },
                "body": {
                  "mode": "raw",
                  "options": { "raw": { "language": "json" } },
                  "raw": "{\n  \"fields\": [\n    {\n      \"key\": \"industry\",\n      \"label\": \"Industry\",\n      \"type\": \"select\",\n      \"required\": false,\n      \"unique\": false,\n      \"order\": 1,\n      \"options\": [\n        { \"value\": \"technology\", \"label\": \"Technology\", \"color\": \"#3B82F6\" },\n        { \"value\": \"retail\",     \"label\": \"Retail\",     \"color\": \"#22C55E\" },\n        { \"value\": \"finance\",    \"label\": \"Finance\",    \"color\": \"#F59E0B\" }\n      ]\n    },\n    {\n      \"key\": \"linkedin_url\",\n      \"label\": \"LinkedIn URL\",\n      \"type\": \"url\",\n      \"required\": false,\n      \"unique\": false,\n      \"order\": 2\n    }\n  ]\n}"
                },
                "description": "**Requires ADMIN.**\n\nFull replacement for the entity. Field types: `text` | `textarea` | `number` | `currency` | `date` | `datetime` | `select` | `multiselect` | `boolean` | `url` | `phone` | `email` | `file` | `relation`"
              }
            },
            {
              "name": "Get field permissions for entity",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/custom-fields/permissions/{{entity}}",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "custom-fields", "permissions", "{{entity}}"]
                },
                "description": "**Requires ADMIN.**\n\nReturns visibility and editability permissions per field key for the entity."
              }
            },
            {
              "name": "Update field permissions for entity",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }
                ],
                "url": {
                  "raw": "{{NEXOURL}}/settings/custom-fields/permissions/{{entity}}",
                  "host": ["{{NEXOURL}}"],
                  "path": ["settings", "custom-fields", "permissions", "{{entity}}"]
                },
                "body": {
                  "mode": "raw",
                  "options": { "raw": { "language": "json" } },
                  "raw": "{\n  \"permissions\": {\n    \"email\":        { \"visibility\": \"all\",          \"editable\": \"manager_plus\" },\n    \"phone\":        { \"visibility\": \"all\",          \"editable\": \"all\"          },\n    \"linkedin_url\": { \"visibility\": \"manager_plus\", \"editable\": \"sales_rep\"    }\n  }\n}"
                },
                "description": "**Requires ADMIN.**\n\nPermission levels: `all` | `manager_plus` | `admin_plus` | `owner_only` | `none`"
              }
            }
          ]
        },

        {
          "name": "Pipelines",
          "item": [
            {
              "name": "List all pipelines",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-tenant-slug", "value": "{{tenantSlug}}", "type": "text" }],
                "url": {
                  "raw": "{{NEXOURL}}/settings/pipelines",
