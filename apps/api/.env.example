# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nexocrm
DATABASE_PASSWORD=nexocrm_dev
DATABASE_NAME=nexocrm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
COOKIE_SECRET=replace-with-random-64-char-secret

# JWT (RS256 — store keys base64-encoded to avoid newline issues)
# Generate keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   JWT_PRIVATE_KEY=$(base64 -i private.pem | tr -d '\n')
#   JWT_PUBLIC_KEY=$(base64 -i public.pem | tr -d '\n')
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_EXPIRES_MS=604800000
